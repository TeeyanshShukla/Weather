{
  "version": 2,
  "builds": [
    {
      "src": "1_frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "2_Backend/Backend.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "2_Backend/Backend.js"
    },
    {
      "src": "/(.*)",
      "dest": "1_frontend/$1"
    }
  ]
}
